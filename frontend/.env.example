# Copy to .env.local for local development
# Point to your Render backend URL in production (set as GitHub secret VITE_API_URL)
VITE_API_URL=http://localhost:3001

# Set to /your-repo-name/ if deploying to GitHub Pages at a subdirectory
# Example: VITE_BASE_PATH=/tennis-bracket-manager/
VITE_BASE_PATH=/
